# Application
NODE_ENV=development
PORT=3000
APP_NAME=Meeting Backend

# Database MongoDB
MONGODB_URI=mongodb://admin:admin123@localhost:27017/meeting_db?authSource=admin
MONGODB_USER=admin
MONGODB_PASSWORD=admin123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_MEMORY=false
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=your_access_token_secret_key_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_token_secret_key_min_32_chars_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Server
ENABLE_SWAGGER=true
SWAGGER_PATH=/api-docs

# LiveKit Cloud
LIVEKIT_URL=wss://your-app.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Firebase Cloud Messaging (choose one credential style)
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
